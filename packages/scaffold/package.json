{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@comment-labs/scaffold",
  "version": "0.1.0-beta.14",
  "description": "CLI for scaffolding consistent repository defaults",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "comment-labs-scaffold": "dist/index.mjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "package-manager-detector": "^1.6.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-dedent": "^2.2.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@comment-labs/oxlint-config": "workspace:*",
    "@comment-labs/tsconfig": "workspace:*",
    "@types/node": "catalog:types",
    "@types/prompts": "catalog:types",
    "oxlint": "catalog:lint",
    "oxlint-tsgolint": "catalog:lint",
    "tsdown": "catalog:toolchain",
    "typescript": "catalog:toolchain"
  },
  "publishConfig": {
    "access": "public"
  }
}
