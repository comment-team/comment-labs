{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@comment-labs/oxlint-config",
  "version": "1.0.0-beta.9",
  "description": "Oxlint configuration for comment-labs projects",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.mjs",
  "files": [
    "dist/",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./plugins/*": "./dist/plugins/*.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "prelint": "pnpm build",
    "lint": "oxlint",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@brettz9/eslint-plugin": "^3.0.0",
    "@e18e/eslint-plugin": "^0.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "empathic": "^2.0.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0"
  },
  "devDependencies": {
    "@comment-labs/tsconfig": "workspace:*",
    "@types/node": "catalog:types",
    "oxlint": "catalog:lint",
    "oxlint-tsgolint": "catalog:lint",
    "tsdown": "catalog:toolchain",
    "typescript": "catalog:toolchain",
    "vitest": "catalog:toolchain"
  },
  "peerDependencies": {
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": ">=0.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
