{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assigneesFromCodeOwners": true,
  "commitMessagePrefix": ":paperclip:",
  "configMigration": true,
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":automergeDigest",
    ":automergeMinor",
    ":automergeRequireAllStatusChecks",
    "npm:unpublishSafe",
    "workarounds:nodeDockerVersioning",
    "workarounds:typesNodeVersioning"
  ],
  "npmrcMerge": true,
  "packageRules": [
    {
      "matchDepTypes": [ "dependencies" ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dependencies{{#if (equals parentDir '')}}{{else}}-{{parentDir}}{{/if}}",
      "commitMessageSuffix": "({{#if (equals parentDir '')}}root{{else}}{{parentDir}}{{/if}})"
    },
    {
      "matchDepTypes": [ "devDependencies" ],
      "matchUpdateTypes": [
          "minor",
          "patch"
      ],
      "rangeStrategy": "pin",
      "groupName": "devDependencies"
    },
    {
      "matchDepTypes": [ "pnpm.overrides" ],
      "enabled": false
    },
    {
      "matchCurrentVersion": "/^(0.)|.*-/",
      "groupName": "{{{depNameSanitized}}}"
    },
    {
      "matchDepNames": [ "zod" ],
      "groupName": "zod"
    },
    {
      "matchDepNames": [ "prisma", "@prisma/client" ],
      "groupName": "prisma"
    },
    {
      "matchDepNames": [ "playwright", "@playwright/test" ],
      "groupName": "playwright"
    },
    {
      "matchDepNames": [ "drizzle-orm", "drizzle-kit", "drizzle-zod" ],
      "groupName": "drizzle"
    },
    {
      "matchDepNames": [
        "@lexical/code",
        "@lexical/link",
        "@lexical/list",
        "@lexical/markdown",
        "@lexical/rich-text",
        "@lexical/selection",
        "@lexical/table",
        "@lexical/utils",
        "lexical",
        "lexical-vue"
      ],
      "groupName": "lexical"
    },
    {
      "matchDepNames": [
        "lucide-vue-next",
        "lucide-react",
        "lucide-react-native"
      ],
      "groupName": "lucide"
    },
    {
      "matchDepNames": [
        "@hcengineering/activity",
        "@hcengineering/api-client",
        "@hcengineering/card",
        "@hcengineering/contact",
        "@hcengineering/core",
        "@hcengineering/tags",
        "@hcengineering/task",
        "@hcengineering/time",
        "@hcengineering/tools",
        "@hcengineering/tracker"
      ],
      "groupName": "{{parentDir}}-huly",
      "prPriority": -1
    },
    {
      "matchPackageNames": [
        "wrangler",
        "@cloudflare/vite-plugin",
        "@cloudflare/workers-types",
        "@cloudflare/vitest-pool-workers"
      ],
      "matchUpdateTypes": [
          "minor",
          "patch"
      ],
      "groupName": "{{parentDir}}-cloudflare"
    },
    {
      "matchPackageNames": [
        "oxlint",
        "oxlint-tsgolint",
        "oxfmt"
      ],
      "matchUpdateTypes": [
          "minor",
          "patch"
      ],
      "groupName": "{{parentDir}}-oxc"
    },
    {
      "matchPackageNames": [
        "better-auth",
        "better-call",
        "auth",
        "@better-auth/telemetry",
        "@better-auth/drizzle-adapter",
        "@better-auth/memory-adapter",
        "@better-auth/mongo-adapter",
        "@better-auth/prisma-adapter",
        "@better-auth/kysely-adapter",
        "@better-auth/redis-storage",
        "@better-auth/utils",
        "@better-auth/passkey",
        "@better-auth/sso",
        "@better-auth/api-key",
        "@better-auth/scim",
        "@better-auth/oauth-provider",
        "@better-auth/stripe",
        "@better-auth/i18n",
        "@better-auth/electron",
        "@better-auth/expo"
      ],
      "groupName": "better-auth",
      "prPriority": -1,
      "automerge": false
    },
    {
      "matchPackageNames": [ "eslint", "bundled-eslint-config" ],
      "groupName": "eslint"
    },
    {
      "matchFileNames": ["pnpm-workspace.yaml"],
      "groupName": "pnpm-workspace",
      "prPriority": -10
    }
  ],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "schedule": [
    "* 1-8 * * *"
  ],
  "timezone": "CET",
  "updateNotScheduled": false
}
